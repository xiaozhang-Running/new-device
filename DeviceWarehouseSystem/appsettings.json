{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DeviceWarehouseSystem.Middleware": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DeviceWarehouse;User Id=sa;Password=1234;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "DeviceWarehouseSystem",
    "Audience": "DeviceWarehouseSystemUsers",
    "AccessTokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "Security": {
    "RequireHttps": false,
    "EnableRateLimiting": true,
    "MaxRequestsPerMinute": 100
  }
}
